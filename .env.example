# ─── Discord ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id_here

# The specific guild + voice channel to sit in permanently
DISCORD_GUILD_ID=123456789012345678
DISCORD_CHANNEL_ID=123456789012345678

# ─── Matrix / Element ─────────────────────────────────────────────────────────
MATRIX_HOMESERVER_URL=https://matrix.example.com
MATRIX_BOT_USER_ID=@voice-bridge-bot:example.com
MATRIX_BOT_ACCESS_TOKEN=syt_your_access_token_here

# The specific Matrix room to sit in permanently
MATRIX_ROOM_ID=!yourRoomId:example.com

# ─── LiveKit ──────────────────────────────────────────────────────────────────
# If you control the LiveKit server, set these.
# If using hosted Element Call (matrix.org etc), leave blank and the bridge
# will fetch tokens from the Matrix homeserver instead.
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Reconnect behaviour ──────────────────────────────────────────────────────
# How long to wait (ms) before retrying a failed connection
RECONNECT_DELAY_MS=5000

# Maximum reconnect attempts before giving up (0 = infinite)
MAX_RECONNECT_ATTEMPTS=0

# How long to wait for an Element Call to appear in the Matrix room (ms)
CALL_WAIT_TIMEOUT_MS=0

# ─── Misc ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=info
HTTP_PORT=3000
